# ===== 数据库 =====
DB_ROOT_PASSWORD=rootpassword
DB_USER=xiaoye
DB_PASSWORD=xiaoye123
DB_NAME=xiaoye

# ===== 必填项 =====
JWT_SECRET=replace_with_a_strong_random_secret
ADMIN_TOKEN=replace_with_your_admin_token

# ===== AI 供应商 (至少配置一个) =====
GOOGLE_API_KEY=your_google_api_key
# ARK_API_KEY=your_volcengine_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI 兼容接口 (NewAPI 等)
# OPENAI_COMPAT_BASE_URL=https://your-newapi.example.com
# OPENAI_COMPAT_API_KEY=your_api_key
# OPENAI_COMPAT_IMAGE_MODEL=gpt-image-1
# OPENAI_COMPAT_IMAGE_DISPLAY_NAME=NewAPI Image
# OPENAI_COMPAT_IMAGE_CREDITS=10

# HTTP 代理 (国内服务器访问 Google 需要，US 环境删除此行)
# HTTP_PROXY=http://127.0.0.1:7890

# ===== 阿里云 OSS 存储 =====
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET_NAME=your_bucket_name
# OSS_REGION=cn-beijing
# OSS_PUBLIC_DOMAIN=http://your-oss-domain.com

# ===== SMTP 邮件 =====
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your_email@qq.com
# SMTP_PASSWORD=your_authorization_code
# SMTP_FROM_EMAIL=your_email@qq.com
# SMTP_FROM_NAME=XiaoYe AI

# ===== OAuth Linux.do =====
# LINUXDO_CLIENT_ID=your_client_id
# LINUXDO_CLIENT_SECRET=your_client_secret
# OAUTH_REDIRECT_URL=https://your-domain.com/oauth/callback

# ===== Linux.do 积分支付 =====
# LINUXDO_CREDIT_PID=your_merchant_pid
# LINUXDO_CREDIT_KEY=your_merchant_key
# LINUXDO_CREDIT_NOTIFY_URL=https://your-domain.com/api/payment/notify/linuxdo
# LINUXDO_CREDIT_RETURN_URL=https://your-domain.com

# ===== 其他 =====
CORS_ORIGINS=http://localhost,http://localhost:81
INSPIRATION_AUTO_APPROVE=false
